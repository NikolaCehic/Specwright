      "type": "object"
    },
    "extractionMethod": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "metadata": {
      "additionalProperties": {},
      "type": "object"
    },
    "redactionPolicy": {
      "anyOf": [
        {
          "enum": [
            "model",
            "adapter",
            "operator",
            "audit",
            "restricted",
            "secret"
          ]
        },
        {
          "additionalProperties": {
            "enum": [
              "model",
              "adapter",
              "operator",
              "audit",
              "restricted",
              "secret"
            ]
          },
          "type": "object"
        }
      ]
    },
    "referencedArtifactRefs": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "referencedToolCallIds": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "sourceRefs": {
      "items": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "additionalProperties": false,
            "properties": {
              "authority": {
                "enum": [
                  "user",
                  "repo",
                  "design",
                  "external",
                  "model",
                  "generated"
