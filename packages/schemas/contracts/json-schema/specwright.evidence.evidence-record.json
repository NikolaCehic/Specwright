{
  "$id": "specwright.evidence.evidence-record",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "authority": {
      "enum": [
        "user",
        "repo",
        "design",
        "external",
        "model",
        "generated"
      ]
    },
    "claim": {
      "type": "string"
    },
    "class": {
      "enum": [
        "source_fact",
        "derived_fact",
        "inference",
        "assumption",
        "human_decision",
        "unknown",
        "conflict"
