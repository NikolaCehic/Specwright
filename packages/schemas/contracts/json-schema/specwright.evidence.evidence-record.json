              "captureToolCallId": {
                "type": "string"
              },
              "contentHash": {
                "type": "string"
              },
              "externalTrustPolicy": {
                "type": "string"
              },
              "id": {
                "type": "string"
              },
              "locator": {
                "type": "string"
              },
              "metadata": {
                "additionalProperties": {},
                "type": "object"
              },
              "path": {
                "type": "string"
              },
              "redactionClass": {
                "enum": [
                  "model",
                  "adapter",
                  "operator",
                  "audit",
                  "restricted",
                  "secret"
                ]
              },
              "snapshotTimestamp": {
