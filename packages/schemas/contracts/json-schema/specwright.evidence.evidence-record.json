    },
    "confidence": {
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "conflictGroup": {
      "type": "string"
    },
    "createdBy": {
      "additionalProperties": false,
      "properties": {
        "actionId": {
          "type": "string"
        },
        "phase": {
          "type": "string"
        },
        "toolCallId": {
          "type": "string"
        }
      },
      "required": [
        "actionId",
        "phase"
