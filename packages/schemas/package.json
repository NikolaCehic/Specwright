{
  "name": "@specwright/schemas",
  "version": "0.0.0",
  "private": true,
  "description": "Shared TypeScript contracts and validation schemas for Specwright.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NikolaCehic/Specwright.git",
    "directory": "packages/schemas"
  },
  "homepage": "https://github.com/NikolaCehic/Specwright#readme",
  "bugs": {
    "url": "https://github.com/NikolaCehic/Specwright/issues"
  },
  "keywords": [
    "specwright",
    "schemas",
    "agent-workflows",
    "runtime-contracts"
  ],
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.1.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "tag": "latest",
    "provenance": true
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./validators": {
      "types": "./dist/validators.d.ts",
      "import": "./dist/validators.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./registry": {
      "types": "./dist/registry.d.ts",
      "import": "./dist/registry.js"
    },
    "./hashes": {
      "types": "./dist/hashes.d.ts",
      "import": "./dist/hashes.js"
    },
    "./fixtures": {
      "types": "./dist/fixtures.d.ts",
      "import": "./dist/fixtures.js"
    },
    "./migrations": {
      "types": "./dist/migrations.d.ts",
      "import": "./dist/migrations.js"
    },
    "./redaction": {
      "types": "./dist/redaction.d.ts",
      "import": "./dist/redaction.js"
    },
    "./event-union": {
      "types": "./dist/event-union.d.ts",
      "import": "./dist/event-union.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "generate": "bun scripts/generate.ts",
    "compat:report": "bun scripts/compat-report.ts",
    "build": "bun run generate && tsc -p tsconfig.build.json --pretty false",
    "typecheck": "tsc --noEmit -p tsconfig.json --pretty false",
    "test": "bun test"
  },
  "dependencies": {
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@specwright/policy-engine": "workspace:*"
  }
}
