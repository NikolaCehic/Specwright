    "@specwright/harness-loader": "workspace:*",
    "@specwright/run-reports": "workspace:*",
    "@specwright/run-store": "workspace:*",
    "@specwright/schemas": "workspace:*",
    "@specwright/trace-recorder": "workspace:*",
    "@specwright/tool-broker": "workspace:*"
