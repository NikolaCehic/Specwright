{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": "src",
    "outDir": "dist",
    "paths": {
      "@specwright/artifact-store": [
        "../artifact-store/dist/index.d.ts"
      ],
      "@specwright/artifact-store/*": [
        "../artifact-store/dist/*"
      ],
      "@specwright/evidence-store": [
        "../evidence-store/dist/index.d.ts"
      ],
      "@specwright/evidence-store/*": [
        "../evidence-store/dist/*"
      ],
      "@specwright/eval-runner": [
        "../eval-runner/dist/index.d.ts"
      ],
      "@specwright/eval-runner/*": [
        "../eval-runner/dist/*"
      ],
      "@specwright/gate-engine": [
        "../gate-engine/dist/index.d.ts"
      ],
      "@specwright/gate-engine/*": [
        "../gate-engine/dist/*"
      ],
      "@specwright/harness-loader": [
        "../harness-loader/dist/index.d.ts"
      ],
      "@specwright/harness-loader/*": [
        "../harness-loader/dist/*"
      ],
      "@specwright/run-reports": [
        "../run-reports/dist/index.d.ts"
      ],
      "@specwright/run-reports/*": [
        "../run-reports/dist/*"
      ],
      "@specwright/run-store": [
        "../run-store/dist/index.d.ts"
      ],
      "@specwright/run-store/*": [
        "../run-store/dist/*"
      ],
      "@specwright/schemas": [
        "../schemas/dist/index.d.ts"
      ],
      "@specwright/schemas/*": [
        "../schemas/dist/*"
      ],
      "@specwright/tool-broker": [
        "../tool-broker/dist/index.d.ts"
      ],
      "@specwright/tool-broker/*": [
        "../tool-broker/dist/*"
      ],
      "@specwright/trace-recorder": [
        "../trace-recorder/dist/index.d.ts"
      ],
      "@specwright/trace-recorder/*": [
        "../trace-recorder/dist/*"
      ]
    }
  }
}
