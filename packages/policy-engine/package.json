{
  "name": "@specwright/policy-engine",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json --pretty false",
    "typecheck": "tsc --noEmit -p tsconfig.json --pretty false",
    "test": "bun test src/index.test.ts",
    "validate:policy": "bun run src/policy-validation.ts"
  },
  "dependencies": {
    "@specwright/schemas": "workspace:*",
    "@specwright/trace-recorder": "workspace:*"
  }
}
