{
  "id": "fixture.fs-read",
  "description": "Allows read-only filesystem access during source and evidence discovery.",
  "toolPolicy": {
    "fs.read": {
      "default": "allow",
      "risk": "low",
      "reason": "fs.read is allowed for source and evidence discovery",
      "allowedPhases": [
        "source_discovery",
        "evidence"
      ],
      "requiredScopes": [
        "workspace:read"
      ],
      "allowedScopes": [
        "workspace:read",
        "evidence:read"
      ],
      "constraints": [
        {
          "kind": "maxBytes",
          "value": 65536
        }
      ],
      "obligations": [
        {
          "kind": "record_event",
          "params": {
            "eventType": "tool.authorized"
          }
        },
        {
          "kind": "require_evidence"
        }
      ]
    }
  }
}
