{
  "id": "fixture.fs-read-budget",
  "description": "Allows fs.read but requires approval when the file-read budget is exceeded.",
  "toolPolicy": {
    "fs.read": {
      "default": "allow",
      "risk": "low",
      "reason": "fs.read is allowed for source and evidence discovery",
      "allowedPhases": [
        "source_discovery",
        "evidence"
      ],
      "requiredScopes": [
        "workspace:read"
      ],
      "allowedScopes": [
        "workspace:read",
        "evidence:read"
      ]
    }
  },
  "budgetPolicy": [
    {
      "id": "budget.file_read_bytes.max",
      "resource": "fileReadBytes",
      "max": 1024,
      "onExceeded": "approval_required",
      "approvalId": "appr_file_read_budget",
      "reason": "file read budget would exceed policy limit",
      "constraints": [
        {
          "kind": "maxBytes",
          "value": 1024
        }
      ],
      "obligations": [
        {
          "kind": "request_human_review",
          "params": {
            "resource": "fileReadBytes"
          }
        }
      ]
    }
  ]
}
