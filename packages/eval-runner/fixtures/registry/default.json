  "entries": [
    {
      "definitionId": "artifact_schema_presence",
      "harnessPackageId": "specwright.default@0.1.0",
      "kind": "artifact_schema",
      "contentHash": "sha256:9130a3b67a1c34c2c0d02bc036ed42d3abbb7f2cb3430986c32b8d0931657cc8",
      "definition": {
        "id": "artifact_schema_presence",
        "description": "Ensure the plan artifact exists and exposes required schema fields.",
        "requiredArtifacts": [
          "plan"
        ],
        "artifactSchemas": [
          "plan"
        ],
        "type": "deterministic",
        "datasetRef": {
          "id": "specwright.default.artifact_schema_presence",
          "version": "1.0.0",
          "path": "packages/eval-runner/fixtures/default-datasets/artifact_schema_presence.json",
          "contentId": "sha256:60908c02ed97ebdc630aef606a1dad54a8769a63be952bea268e6208bfc33604"
        },
        "target": {
          "artifactId": "plan"
        },
        "blocking": true,
        "checks": [
          {
            "id": "plan_required_fields",
            "type": "schema",
            "requiredFields": [
              "goal",
              "steps",
              "claims",
              "sections"
            ]
          },
          {
            "id": "plan_sections_required",
            "type": "schema",
            "path": "sections",
            "requiredFields": [
              "goal",
              "evidence",
              "steps",
              "risks",
              "verification"
            ]
          }
        ],
        "onFail": {
          "action": "create_repair_task"
        },
        "sourcePath": "evals/artifact_schema_presence.yaml"
      }
    },
    {
      "definitionId": "source_fidelity",
      "harnessPackageId": "specwright.default@0.1.0",
