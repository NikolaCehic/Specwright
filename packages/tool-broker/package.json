    "typecheck": "tsc --noEmit -p tsconfig.json --pretty false",
    "test": "bun test src/index.test.ts"
  },
  "dependencies": {
    "@specwright/policy-engine": "workspace:*",
    "@specwright/schemas": "workspace:*",
    "zod": "^3.22.4"
