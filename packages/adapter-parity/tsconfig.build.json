{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": "src",
    "outDir": "dist",
    "paths": {
      "@specwright/cli": [
        "../adapters-cli/dist/index.d.ts"
      ],
      "@specwright/cli/*": [
        "../adapters-cli/dist/*"
      ],
      "@specwright/runtime": [
        "../runtime/dist/index.d.ts"
      ],
      "@specwright/runtime/*": [
        "../runtime/dist/*"
      ],
      "@specwright/run-store": [
        "../run-store/dist/index.d.ts"
      ],
      "@specwright/run-store/*": [
        "../run-store/dist/*"
      ],
      "@specwright/schemas": [
        "../schemas/dist/index.d.ts"
      ],
      "@specwright/schemas/*": [
        "../schemas/dist/*"
      ]
    }
  }
}
