{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "plan",
  "version": "0.1.0",
  "title": "Source-Bound Plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["goal", "nonGoals", "steps", "claims", "assumptions", "sections"],
  "properties": {
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "nonGoals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "description", "evidenceRefs"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "evidenceRefs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "artifacts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "statement", "level"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "statement": {
            "type": "string",
            "minLength": 1
          },
          "level": {
            "type": "string",
            "enum": [
              "source_fact",
              "derived_fact",
              "inference",
              "assumption",
              "human_decision",
              "unknown"
            ]
          },
          "important": {
            "type": "boolean"
          },
          "evidenceRefs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "statement"],
        "properties": {
          "id": {
            "type": "string"
          },
          "statement": {
            "type": "string"
          }
        }
      }
    },
    "sections": {
      "type": "object",
      "additionalProperties": false,
      "required": ["goal", "evidence", "steps", "risks", "verification"],
      "properties": {
        "goal": {
          "type": "object"
        },
        "evidence": {
          "type": "object"
        },
        "steps": {
          "type": "object"
        },
        "risks": {
          "type": "object"
        },
        "verification": {
          "type": "object"
        }
      }
    }
  }
}
