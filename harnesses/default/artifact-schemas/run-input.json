{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "run-input",
  "version": "0.1.0",
  "title": "Run Input",
  "type": "object",
  "additionalProperties": false,
  "required": ["task", "harnessId", "host"],
  "properties": {
    "task": {
      "type": "string",
      "minLength": 1
    },
    "cwd": {
      "type": "string",
      "minLength": 1
    },
    "harnessId": {
      "type": "string",
      "minLength": 1
    },
    "host": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "attachments": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "constraints": {
      "type": "object"
    },
    "metadata": {
      "type": "object"
    }
  }
}
