{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "source-inventory",
  "version": "0.1.0",
  "title": "Source Inventory",
  "type": "object",
  "additionalProperties": false,
  "required": ["sources", "toolCalls", "unknowns"],
  "properties": {
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "path", "kind", "authority"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "authority": {
            "type": "string",
            "minLength": 1
          },
          "hash": {
            "type": "string"
          },
          "evidenceRef": {
            "type": "string"
          }
        }
      }
    },
    "toolCalls": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["toolId", "provenance"],
        "properties": {
          "toolId": {
            "type": "string"
          },
          "provenance": {
            "type": "object"
          }
        }
      }
    },
    "unknowns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
