{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "evidence-graph",
  "version": "0.1.0",
  "title": "Evidence Graph",
  "type": "object",
  "additionalProperties": false,
  "required": ["sources", "records", "claims", "unknowns"],
  "properties": {
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "authority"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string"
          },
          "authority": {
            "type": "string",
            "minLength": 1
          },
          "hash": {
            "type": "string"
          }
        }
      }
    },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "sourceId", "quoteHash"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "sourceId": {
            "type": "string",
            "minLength": 1
          },
          "locator": {
            "type": "string"
          },
          "quoteHash": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string"
          }
        }
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "level", "evidenceRefs"],
        "properties": {
          "id": {
            "type": "string"
          },
          "statement": {
            "type": "string"
          },
          "level": {
            "type": "string"
          },
          "evidenceRefs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "unknowns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "question"],
        "properties": {
          "id": {
            "type": "string"
          },
          "question": {
            "type": "string"
          },
          "blocksPlanning": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
